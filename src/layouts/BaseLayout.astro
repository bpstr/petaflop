---
import '../styles/style.css';
import '../styles/source.css';
import { site } from '../site.config';
import { siteHref } from '../utils/paths';
import { t, type Locale } from '../i18n';
import { CATEGORIES, categoryUrl } from '../utils/categories';

interface Props {
  title: string;
  description?: string;
  pageId?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  hiddenPageTitle?: boolean;
  articlePublishedTime?: string;
  ogImage?: string;
  activeCategory?: string;
}

const {
  title,
  description = site.description,
  pageId = 'page',
  canonicalUrl,
  noindex = false,
  hiddenPageTitle = false,
  articlePublishedTime,
  ogImage = '',
  activeCategory,
} = Astro.props;

const locale = site.language as Locale;
const i18n = t(locale);
const homeHref = siteHref('/');
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();

function normalizePath(pathname: string): string {
  if (!pathname || pathname === '/') return siteHref('/');
  return pathname.endsWith('/') ? pathname : `${pathname}/`;
}

function navCurrent(path: string) {
  const normalized = path.endsWith('/') ? path : `${path}/`;
  const href = siteHref(normalized);
  if (path === '/') return pageId === 'index';
  if (normalized === '/about/') return pageId === 'about';
  if (normalized === '/tools/') return pageId === 'tools';
  if (normalized === '/archive/') return pageId === 'archive';
  if (normalized === '/tags/') return pageId === 'tags';
  if (normalized === '/categories/') return pageId === 'categories';
  return normalizePath(currentPath) === href;
}
---

<!doctype html>
<html lang={i18n.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - {site.title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#ffffff" />
    {noindex ? <meta name="robots" content="noindex" /> : canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content={pageId === 'post' ? 'article' : 'website'} />
    <meta property="og:title" content={`${title} - ${site.title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:image" content={ogImage || `${siteHref('/og-default.png')}`} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {articlePublishedTime && (
      <>
        <meta property="article:published_time" content={articlePublishedTime} />
        <meta property="article:modified_time" content={articlePublishedTime} />
      </>
    )}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={`${title} - ${site.title}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage || `${siteHref('/og-default.png')}`} />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS Feed`} href={siteHref('/rss.xml')} />
    <link rel="alternate" type="application/atom+xml" title={`${site.title} Atom Feed`} href={siteHref('/atom.xml')} />

    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-TXW6XTR8NC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TXW6XTR8NC');
    </script>
  </head>
  <body class={`page-${pageId} source-theme`}>
    <a href="#main-content" class="skip-link">{i18n.skipToContent}</a>

    <div class="gh-viewport">
      <header class="gh-navigation" data-navigation>
        <div class="gh-navigation-inner gh-inner">
          <div class="gh-navigation-brand">
            <a href={homeHref} class="gh-navigation-logo" aria-label={`${site.title} – ${i18n.navHome}`}>
              <span class="gh-navigation-logo-mark" aria-hidden="true">P</span>
              <span>{site.title}</span>
            </a>
          </div>

          <nav class="gh-navigation-menu desktop-nav" aria-label={i18n.mainNavigation}>
            <a href={siteHref('/')} aria-current={navCurrent('/') ? 'page' : undefined}>{i18n.navHome}</a>
            <a href={siteHref('/categories/')} aria-current={navCurrent('/categories') ? 'page' : undefined}>{i18n.navCategories}</a>
            <a href={siteHref('/tools/')} aria-current={navCurrent('/tools') ? 'page' : undefined}>{i18n.navTools}</a>
            <a href={siteHref('/archive/')} aria-current={navCurrent('/archive') ? 'page' : undefined}>{i18n.navArchive}</a>
            <a href={siteHref('/about/')} aria-current={navCurrent('/about') ? 'page' : undefined}>{i18n.navAbout}</a>
          </nav>

          <div class="gh-navigation-actions">
            <a class="gh-icon-button" href={siteHref('/archive/')} aria-label={i18n.navArchive} title={i18n.navArchive}>
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"></circle><path d="m16 16 4 4"></path></svg>
            </a>
            <a class="gh-button gh-button-small" href={siteHref('/feed/')}>{i18n.rssSubscribe}</a>

            <details class="mobile-nav-menu">
              <summary aria-label={i18n.navMenu}>
                <span class="visually-hidden">{i18n.navMenu}</span>
                <span class="hamburger-icon" aria-hidden="true"></span>
              </summary>
              <nav class="mobile-nav-links" aria-label={i18n.mainNavigation}>
                <a href={siteHref('/')}>{i18n.navHome}</a>
                <a href={siteHref('/categories/')}>{i18n.navCategories}</a>
                <a href={siteHref('/tools/')}>{i18n.navTools}</a>
                <a href={siteHref('/archive/')}>{i18n.navArchive}</a>
                <a href={siteHref('/tags/')}>{i18n.navTags}</a>
                <a href={siteHref('/about/')}>{i18n.navAbout}</a>
              </nav>
            </details>
          </div>
        </div>

        <nav class="gh-topic-nav" aria-label={i18n.categoryNavLabel}>
          <div class="gh-topic-nav-inner gh-inner">
            {CATEGORIES.map((category) => (
              <a href={categoryUrl(category.slug)} aria-current={activeCategory === category.slug ? 'page' : undefined}>
                {category.label}
              </a>
            ))}
          </div>
        </nav>
      </header>

      <main id="main-content" class="gh-site-main">
        {hiddenPageTitle && <h1 class="visually-hidden">{title}</h1>}
        <div class="gh-main-shell">
          <div class="gh-main-content"><slot /></div>
          <slot name="toc" />
        </div>
      </main>

      <footer class="gh-footer gh-outer">
        <div class="gh-footer-inner gh-inner">
          <div class="gh-footer-brand">
            <a href={homeHref} class="gh-footer-logo">{site.title}</a>
            <p>{site.description}</p>
          </div>
          <div class="gh-footer-columns">
            <nav aria-label={i18n.mainNavigation}>
              <h2>Magazin</h2>
              <a href={siteHref('/archive/')}>{i18n.navArchive}</a>
              <a href={siteHref('/categories/')}>{i18n.navCategories}</a>
              <a href={siteHref('/tags/')}>{i18n.navTags}</a>
            </nav>
            <nav aria-label="Petaflop">
              <h2>Petaflop</h2>
              <a href={siteHref('/tools/')}>{i18n.navTools}</a>
              <a href={siteHref('/about/')}>{i18n.navAbout}</a>
              <a href={siteHref('/feed/')}>{i18n.rssSubscribe}</a>
            </nav>
          </div>
        </div>
        <div class="gh-footer-bar gh-inner">
          <span>&copy; {year} {site.author}</span>
          <a href="#main-content">{i18n.backToTop}</a>
        </div>
      </footer>
    </div>
  </body>
</html>
