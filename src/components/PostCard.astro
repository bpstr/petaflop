---
import type { Post } from '../utils/posts';
import { formatDate, postCategoryUrl, postUrl } from '../utils/posts';
import { site } from '../site.config';
import { categoryLabel } from '../utils/categories';

interface Props {
  post: Post;
  variant?: 'list' | 'grid' | 'compact';
  eager?: boolean;
}

const { post, variant = 'list', eager = false } = Astro.props;
const url = postUrl(post);
const dateStr = formatDate(post.data.date, site.language);
---

<article class={`gh-card is-${variant}${post.data.cover ? ' has-image' : ' no-image'}`}>
  <a class="gh-card-link" href={url}>
    {post.data.cover && (
      <figure class="gh-card-image">
        <img
          src={post.data.cover}
          alt={post.data.title}
          loading={eager ? 'eager' : 'lazy'}
          decoding="async"
        />
      </figure>
    )}
    <div class="gh-card-wrapper">
      <p class="gh-card-tag">{categoryLabel(post.data.category)}</p>
      <h2 class="gh-card-title">{post.data.title}</h2>
      {post.data.summary && <p class="gh-card-excerpt">{post.data.summary}</p>}
      <footer class="gh-card-meta">
        <span>{site.author}</span>
        <time datetime={post.data.date.toISOString()}>{dateStr}</time>
      </footer>
    </div>
  </a>
</article>
