---
import type { Post } from '../utils/posts';
import { formatDate, postUrl, tagUrl } from '../utils/posts';
import { site } from '../site.config';
import { badgeClass } from '../utils/badge';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const url = postUrl(post);
const dateStr = formatDate(post.data.date, site.language);
---

<article class="post-list-item" data-href={url}>
  <h2 class="post-title">
    <a href={url} class="post-title-link">{post.data.title}</a>
  </h2>
  <div class="post-list-meta-line">
    <span class="meta-date-wrapper">{dateStr}</span>
    {post.data.tags.length > 0 && (
      <div class="tags-wrapper">
        {post.data.tags.map((tag, i) => (
          <a href={tagUrl(tag)} class={`badge-pill ${badgeClass(i)}`}>{tag}</a>
        ))}
      </div>
    )}
  </div>
  {post.data.summary && <p class="post-excerpt">{post.data.summary}</p>}
</article>
<script>
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;

    const article = target.closest<HTMLElement>(".post-list-item");
    if (!article) return;

    if (target.closest("a")) return;

    if (article.dataset.href) window.location.href = article.dataset.href;
  });
</script>
