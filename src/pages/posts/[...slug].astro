---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Copyright from '../../components/Copyright.astro';
import PostCard from '../../components/PostCard.astro';
import TocNav from '../../components/TocNav.astro';
import { site } from '../../site.config';
import { t } from '../../i18n';
import { absoluteUrl } from '../../utils/paths';
import {
  formatDate,
  getAdjacentPosts,
  getBlogPosts,
  getRelatedPosts,
  postCategoryUrl,
  postSlug,
  postUrl,
  tagUrl,
  type Post,
} from '../../utils/posts';
import { render } from 'astro:content';
import { categoryLabel } from '../../utils/categories';

export async function getStaticPaths() {
  const allBlogPosts = await getBlogPosts();
  return allBlogPosts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post, allBlogPosts },
  }));
}

interface Props {
  post: Post;
  allBlogPosts: Post[];
}

const { post, allBlogPosts } = Astro.props;
const { Content, headings } = await render(post);
const { prev, next } = getAdjacentPosts(allBlogPosts, post);
const relatedPosts = getRelatedPosts(allBlogPosts, post).slice(0, 3);
const i18n = t(site.language);
const canonicalUrl = absoluteUrl(`/posts/${postSlug(post)}/`);
const dateIso = post.data.date.toISOString().split('T')[0];
const articlePublishedIso = post.data.date.toISOString();
const tocHeadings = headings.map((heading) => ({
  depth: heading.depth,
  slug: heading.slug,
  text: heading.text,
}));
const hasToc = tocHeadings.some((heading) => heading.depth >= 1 && heading.depth <= 4);
---

<BaseLayout
  title={post.data.title}
  description={post.data.summary}
  pageId="post"
  canonicalUrl={canonicalUrl}
  articlePublishedTime={articlePublishedIso}
  ogImage={post.data.cover}
  activeCategory={post.data.category}
>
  <article class="gh-article" itemscope itemtype="https://schema.org/Article">
    <link itemprop="mainEntityOfPage" href={canonicalUrl} />
    <meta itemprop="description" content={post.data.summary ?? site.description} />
    <meta itemprop="author" content={site.author} />
    <meta itemprop="publisher" content={site.title} />

    <header class={`gh-article-header gh-outer${post.data.cover ? ' has-image' : ' no-image'}`}>
      <div class="gh-article-header-inner gh-inner">
        <div class="gh-article-header-content">
          <a href={postCategoryUrl(post)} class="gh-article-tag">{categoryLabel(post.data.category)}</a>
          <h1 itemprop="headline">{post.data.title}</h1>
          {post.data.summary && <p class="gh-article-excerpt">{post.data.summary}</p>}
          <div class="gh-article-meta">
            <span>{site.author}</span>
            <time datetime={dateIso} itemprop="datePublished dateModified">
              {formatDate(post.data.date, site.language)}
            </time>
          </div>
          {post.data.tags.length > 0 && (
            <div class="gh-article-tags" aria-label={i18n.navTags}>
              {post.data.tags.map((tag) => <a href={tagUrl(tag)}>#{tag}</a>)}
            </div>
          )}
        </div>

        {post.data.cover && (
          <figure class="gh-article-image">
            <img src={post.data.cover} alt={post.data.title} loading="eager" decoding="async" />
          </figure>
        )}
      </div>
    </header>

    <div class="gh-article-body gh-outer">
      <div class="gh-article-body-inner gh-inner">
        {hasToc && (
          <details class="mobile-toc">
            <summary>{i18n.toc}</summary>
            <nav class="mobile-toc-content" aria-label={i18n.toc}>
              <TocNav headings={tocHeadings} />
            </nav>
          </details>
        )}

        <div class="post-content gh-content" itemprop="articleBody">
          <Content />
        </div>

        <Copyright postTitle={post.data.title} canonicalUrl={canonicalUrl} />
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <section class="gh-related gh-outer" aria-labelledby="related-posts-heading">
        <div class="gh-inner">
          <div class="gh-section-heading">
            <h2 id="related-posts-heading">{i18n.relatedPosts}</h2>
          </div>
          <div class="gh-topic-grid">
            {relatedPosts.map((relatedPost) => <PostCard post={relatedPost} variant="grid" />)}
          </div>
        </div>
      </section>
    )}

    {(prev || next) && (
      <nav class="gh-post-navigation gh-outer" aria-label="Cikk navigáció">
        <div class="gh-post-navigation-inner gh-inner">
          {prev ? (
            <a href={postUrl(prev)} class="gh-post-navigation-link is-prev">
              <small>← {i18n.prevPost}</small>
              <strong>{prev.data.title}</strong>
            </a>
          ) : <span />}
          {next ? (
            <a href={postUrl(next)} class="gh-post-navigation-link is-next">
              <small>{i18n.nextPost} →</small>
              <strong>{next.data.title}</strong>
            </a>
          ) : <span />}
        </div>
      </nav>
    )}
  </article>

  {hasToc && (
    <nav slot="toc" class="gh-post-toc" aria-label={i18n.toc}>
      <h2>{i18n.toc}</h2>
      <TocNav headings={tocHeadings} />
    </nav>
  )}
</BaseLayout>
