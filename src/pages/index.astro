---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { site } from '../site.config';
import { t } from '../i18n';
import { siteHref } from '../utils/paths';
import { formatDate, getAllTags, getBlogPosts, getPostsByCategory, postUrl, tagUrl } from '../utils/posts';
import { CATEGORIES, categoryLabel, categoryUrl } from '../utils/categories';

const blogPosts = await getBlogPosts();
const homePosts = blogPosts.slice(0, Math.max(site.maxPostsOnIndex, 12));
const locale = site.language;
const i18n = t(locale);
const canonicalUrl = new URL('/', Astro.site).href;
const [leadPost, ...remainingPosts] = homePosts;
const featuredPosts = remainingPosts.slice(0, 3);
const feedPosts = remainingPosts.slice(3);
const allTags = getAllTags(blogPosts).slice(0, 12);
const categorySections = CATEGORIES.map((category) => ({
  category,
  posts: getPostsByCategory(blogPosts, category.slug).slice(0, 3),
})).filter((section) => section.posts.length > 0);
---

<BaseLayout title={i18n.pageHome} pageId="index" canonicalUrl={canonicalUrl} hiddenPageTitle>
  {homePosts.length === 0 ? (
    <p class="empty-state">{i18n.noPosts}</p>
  ) : (
    <div class="gh-home">
      <section class="gh-home-intro gh-outer">
        <div class="gh-inner">
          <p class="gh-home-kicker">Mesterséges intelligencia · számítási teljesítmény · technológia</p>
          <h1>{site.title}</h1>
          <p>{site.description}</p>
        </div>
      </section>

      {leadPost && (
        <section class="gh-featured gh-outer">
          <div class="gh-featured-inner gh-inner">
            <article class={`gh-featured-main${leadPost.data.cover ? ' has-image' : ' no-image'}`}>
              <a href={postUrl(leadPost)} class="gh-featured-link">
                {leadPost.data.cover && (
                  <figure class="gh-featured-image">
                    <img src={leadPost.data.cover} alt={leadPost.data.title} loading="eager" decoding="async" />
                  </figure>
                )}
                <div class="gh-featured-content">
                  <p class="gh-card-tag">{categoryLabel(leadPost.data.category)}</p>
                  <h2>{leadPost.data.title}</h2>
                  {leadPost.data.summary && <p>{leadPost.data.summary}</p>}
                  <footer>
                    <span>{site.author}</span>
                    <time datetime={leadPost.data.date.toISOString()}>{formatDate(leadPost.data.date, locale)}</time>
                  </footer>
                </div>
              </a>
            </article>

            <div class="gh-featured-side">
              {featuredPosts.map((post) => <PostCard post={post} variant="compact" />)}
            </div>
          </div>
        </section>
      )}

      <section class="gh-container has-sidebar gh-outer">
        <div class="gh-container-inner gh-inner">
          <main class="gh-feed-main">
            <div class="gh-section-heading">
              <h2>Legfrissebb</h2>
              <a href={siteHref('/archive/')}>Összes cikk →</a>
            </div>
            <div class="gh-feed">
              {feedPosts.map((post) => <PostCard post={post} variant="list" />)}
            </div>
          </main>

          <aside class="gh-sidebar">
            <div class="gh-sidebar-inner">
              <section class="gh-about">
                <div class="gh-about-icon" aria-hidden="true">P</div>
                <h2>{site.title}</h2>
                <p>{site.description}</p>
                <a class="gh-button" href={siteHref('/feed/')}>{i18n.rssSubscribe}</a>
              </section>
              {allTags.length > 0 && (
                <section class="gh-sidebar-section">
                  <h2>Témák</h2>
                  <div class="gh-tag-cloud">
                    {allTags.map((tag) => <a href={tagUrl(tag)}>{tag}</a>)}
                  </div>
                </section>
              )}
            </div>
          </aside>
        </div>
      </section>

      <section class="gh-topic-sections gh-outer">
        <div class="gh-inner">
          {categorySections.map(({ category, posts }) => (
            <section class="gh-topic-section">
              <div class="gh-section-heading">
                <div>
                  <h2>{category.label}</h2>
                  <p>{category.description}</p>
                </div>
                <a href={categoryUrl(category.slug)}>További cikkek →</a>
              </div>
              <div class="gh-topic-grid">
                {posts.map((post) => <PostCard post={post} variant="grid" />)}
              </div>
            </section>
          ))}
        </div>
      </section>
    </div>
  )}
</BaseLayout>
