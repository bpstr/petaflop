---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
import { t } from '../i18n';
import { siteHref } from '../utils/paths';
import { formatDate, getAllTags, getBlogPosts, getPostsByCategory, postUrl, tagUrl } from '../utils/posts';
import { badgeClass, featureCardClass } from '../utils/badge';
import { CATEGORIES, categoryUrl } from '../utils/categories';
import PostCard from "../components/PostCard.astro";

const blogPosts = await getBlogPosts();
const indexPosts = blogPosts.slice(0, site.maxPostsOnIndex);
const locale = site.language;
const i18n = t(locale);
const canonicalUrl = new URL('/', Astro.site).href;
const [leadPost, ...remainingPosts] = indexPosts;
const featuredPosts = remainingPosts.slice(0, 2);
const briefingPosts = remainingPosts.slice(2, 6);
const coverPosts = blogPosts.filter((post) => post.data.cover).slice(0, 2);
const allTags = getAllTags(blogPosts).slice(0, 10);
/** Homepage sections: each category with its latest posts (skip empty ones). */
const categorySections = CATEGORIES.map((category) => ({
  category,
  posts: getPostsByCategory(blogPosts, category.slug).slice(0, 4),
})).filter((section) => section.posts.length > 0);
const latestDate = leadPost ? formatDate(leadPost.data.date, locale) : '';
const leadUrl = leadPost ? postUrl(leadPost) : siteHref('/archive/');
const leadTags = leadPost?.data.tags.slice(0, 3) ?? [];
const primaryVisual = leadPost;
const secondaryVisual = coverPosts.find((post) => post.id !== leadPost?.id);
---

<BaseLayout title={i18n.pageHome} pageId="index" canonicalUrl={canonicalUrl} hiddenPageTitle>
  {indexPosts.length === 0 ? (
    <p class="empty-state">{i18n.noPosts}</p>
  ) : (
    <div class="bg-canvas text-ink dark:bg-surface-dark dark:text-on-dark">
      <section class="border-b border-hairline py-6 dark:border-[#2a3a3a] md:py-8">
        <p class="mb-2 inline-flex rounded-full border border-hairline bg-white px-3 py-1 text-[11px] font-semibold uppercase leading-none text-muted dark:border-[#2a3a3a] dark:bg-surface-dark-elevated dark:text-on-dark-soft">
          AI hírek és számítási teljesítmény
        </p>
        <h1 class="m-0 text-4xl font-medium leading-[1.05] tracking-tight sm:text-5xl">
          Petaflop
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-7 text-body dark:text-on-dark-soft">
          Magyar magazin az AI-laborok, szuperszámítógépek, modellek és iparági döntések nagy teljesítményű világából.
          <span class="text-muted dark:text-on-dark-soft"> Friss lapszám: {latestDate}</span>
        </p>
      </section>

      <section class="border-b border-hairline py-6 dark:border-[#2a3a3a] md:py-8">
        <article class="grid gap-5 rounded-lg border border-hairline bg-white p-4 dark:border-[#2a3a3a] dark:bg-surface-dark-elevated sm:grid-cols-2 sm:p-5">
          <div class="overflow-hidden rounded-lg border border-hairline-soft bg-surface-soft dark:border-[#2a3a3a] dark:bg-surface-dark-elevated sm:order-2">
            {primaryVisual?.data.cover ? (
              <a href={postUrl(primaryVisual)} class="group block h-full min-h-[180px] no-underline">
                <img
                  src={primaryVisual.data.cover}
                  alt=""
                  class="h-full min-h-[180px] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                  loading="eager"
                />
              </a>
            ) : (
              <div class="grid h-full min-h-[180px] place-items-center p-6 text-center">
                <p class="font-mono text-sm leading-6 text-body dark:text-on-dark-soft">compute / model / market / policy</p>
              </div>
            )}
          </div>

          <div class="flex flex-col justify-between sm:order-1">
            <div>
              <div class="mb-3 flex flex-wrap gap-2">
                {leadTags.map((tag, i) => (
                  <a href={tagUrl(tag)} class={`badge-pill ${badgeClass(i)}`}>
                    {tag}
                  </a>
                ))}
              </div>
              <a href={leadUrl} class="group no-underline">
                <h2 class="m-0 text-2xl font-medium leading-tight tracking-tight group-hover:!text-accent dark:group-hover:!text-brand-mint sm:text-3xl">
                  {leadPost.data.title}
                </h2>
              </a>
              {leadPost.data.summary && <p class="mt-3 text-sm leading-6 text-body dark:text-on-dark-soft">{leadPost.data.summary}</p>}
            </div>
            <a href={leadUrl} class="button-primary mt-4 w-fit">
              Cikk olvasása
            </a>
          </div>
        </article>

        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {featuredPosts.map((post, index) => (
            <article class={`feature-card ${featureCardClass(index)} !p-4`}>
              <p class="mb-2 text-[11px] font-semibold uppercase opacity-80">
                Kiemelt
              </p>
              <a href={postUrl(post)} class="group no-underline">
                <h3 class="m-0 text-lg font-medium leading-tight tracking-tight group-hover:underline">
                  {post.data.title}
                </h3>
              </a>
              {post.data.summary && <p class="mt-2 text-sm leading-6 opacity-90">{post.data.summary}</p>}
            </article>
          ))}
        </div>
      </section>

      <section class="py-6 md:py-8">
        <div class="mb-3 flex items-end justify-between gap-4 border-b border-hairline pb-3 dark:border-[#2a3a3a]">
          <h2 class="m-0 text-xl font-medium tracking-tight">Hírfolyam</h2>
          <a href={siteHref('/archive/')} class="text-sm font-medium no-underline">Archívum</a>
        </div>
        <div class="divide-y divide-hairline border-b border-hairline dark:divide-[#2a3a3a] dark:border-[#2a3a3a]">
          {briefingPosts.map((post) => (
              <PostCard post={post} />
          ))}
        </div>

        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          {secondaryVisual?.data.cover && (
            <a href={postUrl(secondaryVisual)} class="group flex overflow-hidden rounded-lg border border-hairline bg-white no-underline dark:border-[#2a3a3a] dark:bg-surface-dark-elevated">
              <img src={secondaryVisual.data.cover} alt="" class="w-28 shrink-0 object-cover transition duration-300 group-hover:scale-[1.02]" loading="lazy" />
              <div class="flex flex-col justify-center p-3">
                <p class="mb-1 text-[11px] font-semibold uppercase text-muted dark:text-on-dark-soft">Képes riport</p>
                <h3 class="m-0 text-sm font-medium leading-tight tracking-tight group-hover:!text-accent dark:group-hover:!text-brand-mint">{secondaryVisual.data.title}</h3>
              </div>
            </a>
          )}

          <div class="rounded-lg border border-hairline bg-white p-4 dark:border-[#2a3a3a] dark:bg-surface-dark-elevated">
            <h2 class="m-0 text-sm font-medium tracking-tight">Témák</h2>
            <div class="mt-3 flex flex-wrap gap-2">
              {allTags.map((tag, i) => (
                <a href={tagUrl(tag)} class={`badge-pill ${badgeClass(i)}`}>
                  {tag}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      {categorySections.map(({ category, posts }) => (
        <section class="border-t border-hairline py-6 dark:border-[#2a3a3a] md:py-8">
          <div class="mb-3 flex items-end justify-between gap-4 border-b border-hairline pb-3 dark:border-[#2a3a3a]">
            <div>
              <h2 class="m-0 text-xl font-medium tracking-tight">{category.label}</h2>
              <p class="mt-1 text-sm leading-6 text-muted dark:text-on-dark-soft">{category.description}</p>
            </div>
            <a href={categoryUrl(category.slug)} class="shrink-0 text-sm font-medium no-underline">{i18n.allCategories} →</a>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {posts.map((post) => (
              <article class="rounded-lg border border-hairline bg-white p-4 dark:border-[#2a3a3a] dark:bg-surface-dark-elevated">
                <time class="text-xs text-muted dark:text-on-dark-soft" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date, locale)}
                </time>
                <a href={postUrl(post)} class="group no-underline">
                  <h3 class="mt-1 text-lg font-medium leading-tight tracking-tight group-hover:!text-accent dark:group-hover:!text-brand-mint">
                    {post.data.title}
                  </h3>
                </a>
                {post.data.summary && <p class="mt-1 text-sm leading-6 text-body dark:text-on-dark-soft">{post.data.summary}</p>}
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  )}

  {blogPosts.length >= site.maxPostsOnIndex && (
    <div class="read-more-link-area">
      <a href={siteHref('/archive/')} class="button button-secondary">{i18n.readAllArchive} -&gt;</a>
    </div>
  )}
</BaseLayout>
