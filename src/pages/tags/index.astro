---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../site.config';
import { t } from '../../i18n';
import { getAllTags, getBlogPosts, tagUrl } from '../../utils/posts';
import { badgeClass } from '../../utils/badge';

const blogPosts = await getBlogPosts();
const tags = getAllTags(blogPosts);
const tagCounts = tags.map((tag) => ({
  tag,
  count: blogPosts.filter((p) => p.data.tags.includes(tag)).length,
}));
tagCounts.sort((a, b) => b.count - a.count);
const i18n = t(site.language);
const canonicalUrl = new URL('/tags/', Astro.site).href;
---

<BaseLayout title={i18n.pageTags} pageId="tags" canonicalUrl={canonicalUrl} hiddenPageTitle>
  <h1>{i18n.tagsListHeading}</h1>
  {tagCounts.length === 0 ? (
    <p class="empty-state">{i18n.noTags}</p>
  ) : (
    <div class="tag-cloud">
      {tagCounts.map(({ tag, count }, i) => (
        <a href={tagUrl(tag)} class={`badge-pill ${badgeClass(i)}`}>
          {tag} ({count})
        </a>
      ))}
    </div>
  )}
</BaseLayout>
