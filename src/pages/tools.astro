---
import { getCollection } from 'astro:content';
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from '../site.config';
import { t } from '../i18n';
import { absoluteUrl } from '../utils/paths';
import { badgeClass } from '../utils/badge';

const i18n = t(site.language);
const canonicalUrl = absoluteUrl('/tools/');

const tools = await getCollection('tools');

// Optional: sort featured first, then alphabetically
tools.sort((a, b) => {
    const af = a.data.featured ? 0 : 1;
    const bf = b.data.featured ? 0 : 1;
    return af - bf || a.data.name.localeCompare(b.data.name);
});
---

<BaseLayout
    title={i18n.pageAbout}
    description={site.description}
    pageId="tools"
    canonicalUrl={canonicalUrl}
>
  <div class="page-header">
    <h1>AI Tools Directory</h1>
    <p>Curated list of useful AI tools and platforms.</p>
  </div>
  <div class="post-content">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((tool, i) => (
          <a
            class="feature-card-cream flex flex-col gap-2 rounded-lg border border-hairline p-5 no-underline transition-transform hover:-translate-y-0.5 dark:border-[#2a3a3a]"
            href={tool.data.url}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="flex items-center justify-between gap-2">
              <h2 class="m-0 text-lg font-semibold">{tool.data.name}</h2>
              {tool.data.featured && <span class={`badge-pill ${badgeClass(i)}`}>Featured</span>}
            </div>

            {tool.data.provider && (
                <p class="m-0 text-sm text-muted dark:text-on-dark-soft">{tool.data.provider}</p>
            )}

            {tool.data.description && (
                <p class="m-0 text-sm leading-6 text-body dark:text-on-dark-soft">{tool.data.description}</p>
            )}

            <p class="m-0 mt-auto pt-2 text-xs font-semibold uppercase tracking-wide text-muted-soft dark:text-on-dark-soft">{tool.data.category}</p>
          </a>
      ))}
    </div>
  </div>
</BaseLayout>
